# ─────────────────────────────────────────────────────────────────────
# .env.example — variables d'environnement htassurance.fr
#
# Copier ce fichier en .env.local pour le développement, et configurer
# chaque variable dans Vercel → Settings → Environment Variables pour
# la production.
#
# RÈGLE : tout ce qui commence par NEXT_PUBLIC_ est exposé dans le HTML
# (visible dans le navigateur). Tout le reste reste server-only.
# ─────────────────────────────────────────────────────────────────────

# === Google Maps Embed (TÂCHE A) ===
# Restreinte par référent HTTP : htassurance.fr/* + *.vercel.app/*
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyAaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaA

# === Google Places API (TÂCHE B) ===
# Server-only, restreinte par API à "Places API (New)" UNIQUEMENT.
GOOGLE_PLACES_API_KEY=AIzaSyAaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaA
# Place ID de la fiche principale (siège Trachel).
GOOGLE_PLACE_ID=ChIJuSypYgbQzRIRqX2X-zuw5ao

# === reCAPTCHA v3 (TÂCHE C) ===
# Site key (publique) — visible dans le HTML, OK.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Ldxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret key (privée) — server-only.
RECAPTCHA_SECRET_KEY=6Ldxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Resend (TÂCHE C — emails formulaire contact) ===
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Google Analytics 4 (TÂCHE D) ===
# Measurement ID au format G-XXXXXXXXXX (PAS le Property ID 9-chiffres).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === Search Console API (TÂCHE E) ===
# JSON du compte de service, copié-collé en une variable. Voir
# docs/setup-search-console-api.md pour la procédure complète.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# === Admin dashboard (TÂCHE E) ===
# Mot de passe pour accéder à /admin/seo. Générer avec :
#   openssl rand -base64 32
ADMIN_PASSWORD=changeme-please-use-openssl-rand

# === Anciens compatibilité ===
# Conservé pour rétrocompat — le code lit NEXT_PUBLIC_GA_MEASUREMENT_ID en priorité.
NEXT_PUBLIC_GA_ID=G-SLL7N7KBG7

# === KV optionnel (rate limiting Upstash, futur) ===
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# === Vercel system vars (auto-injectées, ne pas définir) ===
# VERCEL_URL
# VERCEL_ENV
